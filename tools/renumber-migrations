#!/usr/bin/env python3
import argparse
import fileinput
import glob
import os
import re
import sys

# When we need to backport migrations to a previous release, we
# sometimes end up with multiple having the same ID number (which
# isn't a problem; the migrations graph structure, not the IDs, is
# what matters).
MIGRATIONS_TO_SKIP = {"0209", "0261", "0501", "0001"}


def validate_order(order: list[int], length: int) -> None:
    if sorted(order) != list(range(1, length + 1)):
        print(f"Expected a permutation of 1..{length}; got: {order}")
        sys.exit(1)


def renumber_one(
    filename: str,
    new_number: int,
    new_predecessor: str,
    migrations_dir: str,
    app_label: str,
) -> str:
    """Rewrite the file's in-app dep tuples to point at new_predecessor, then rename it."""
    path = os.path.join(migrations_dir, filename)
    # Match only ("<app_label>", "NNNN_xxx") tuples, not things like
    # `1_000` or cross-app deps. ruff-format always puts `, ` between
    # the two tuple elements, so the replacement hardcodes that.
    dep_pattern = re.compile(rf'"{re.escape(app_label)}"\s*,\s*"\d+(?:_[a-z0-9]+)+"')
    # Don't touch migration-merge files: with two in-app deps in the
    # same file, the substitution would collapse both to the same
    # predecessor and produce a self-referential migration.
    with open(path) as f:
        if len(dep_pattern.findall(f.read())) > 1:
            print(
                f"Refusing to renumber {filename}: it has multiple "
                f"in-app dependencies (a migration merge). Renumber it by hand."
            )
            sys.exit(1)
    replacement = f'"{app_label}", "{new_predecessor}"'
    with fileinput.FileInput(path, inplace=True) as f:
        for line in f:
            print(dep_pattern.sub(replacement, line), end="")
    new_name = f"{new_number:04}{filename[4:]}"
    os.rename(path, os.path.join(migrations_dir, new_name))
    return new_name


def renumber_migration(
    conflicts: list[str],
    order: list[int],
    last_correct_migration: str,
    migrations_dir: str,
    app_label: str,
) -> None:
    seen_prefixes: set[str] = set()
    for i in order:
        prefix = conflicts[i - 1][0:4]
        if prefix not in seen_prefixes:
            seen_prefixes.add(prefix)
            continue
        new_number = int(last_correct_migration[0:4]) + 1
        new_name = renumber_one(
            conflicts[i - 1], new_number, last_correct_migration, migrations_dir, app_label
        )
        last_correct_migration = new_name.removesuffix(".py")


def resolve_conflicts(conflicts: list[str], migrations_dir: str, app_label: str) -> None:
    print("Conflicting migrations:")
    for i, name in enumerate(conflicts, 1):
        print(f"{i}. {name}")

    order_input = input("Enter the order in which these migrations should be arranged: ")
    order = list(map(int, order_input.split()))
    validate_order(order, len(conflicts))

    last_correct_migration = conflicts[order[0] - 1].removesuffix(".py")
    renumber_migration(conflicts, order, last_correct_migration, migrations_dir, app_label)


def main() -> None:
    parser = argparse.ArgumentParser(description="Renumber migration files.")
    parser.add_argument(
        "app_label",
        nargs="?",
        default="zerver",
        help="The Django app label to process (e.g. zerver, analytics)",
    )
    args = parser.parse_args()

    migrations_dir = os.path.join(args.app_label, "migrations")
    if not os.path.exists(migrations_dir):
        print(f"Error: Directory '{migrations_dir}' does not exist.")
        sys.exit(1)

    while True:
        files_list = [
            os.path.basename(path) for path in glob.glob(os.path.join(migrations_dir, "????_*.py"))
        ]
        prefixes = [file[0:4] for file in files_list]

        conflicts: list[str] = []
        seen_prefixes: set[str] = set()
        for prefix in prefixes:
            if (
                prefixes.count(prefix) > 1
                and prefix not in seen_prefixes
                and prefix not in MIGRATIONS_TO_SKIP
            ):
                conflicts += [f for f in files_list if f.startswith(prefix)]
                seen_prefixes.add(prefix)

        if not conflicts:
            break
        resolve_conflicts(conflicts, migrations_dir, args.app_label)

    print("All conflicts resolved")


if __name__ == "__main__":
    main()
