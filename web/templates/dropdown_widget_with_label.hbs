<div class="input-group" id="{{#if prefix}}{{prefix}}{{else}}id_{{/if}}{{widget_name}}_widget_container">
    <label class="settings-field-label" for="{{#if prefix}}{{prefix}}{{else}}id_{{/if}}{{widget_name}}_widget">{{label}}
        {{#if help_link}}{{> help_link_widget link=help_link }}{{/if}}
    </label>
    <span class="prop-element hide" id="{{#if prefix}}{{prefix}}{{else}}id_{{/if}}{{widget_name}}" data-setting-widget-type="dropdown-list-widget" {{#if value_type}}data-setting-value-type="{{value_type}}"{{/if}}></span>
    <div class="dropdown_widget_with_label_wrapper">
        {{> dropdown_widget .}}
    </div>
</div>
