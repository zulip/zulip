<div id="tenor_grid_in_popover" class="gif-grid-in-popover">
    <div class="arrow"></div>
    <div class="popover-inner">
        <div class="popover-filter-input-wrapper">
            <input type="text" id="tenor-search-query" class="popover-filter-input filter_text_input" autocomplete="off" placeholder="{{t 'Search Tenor' }}" autofocus/>
        </div>
        <div class="gif-scrolling-container" data-simplebar data-simplebar-tab-index="-1">
            {{! We need a container we can replace
            without removing the simplebar wrappers.
            We replace the `tenor-content` when
            searching for GIFs. }}
            <div class="tenor-content"></div>
        </div>
        <div class="popover-footer">
            <img src="../images/tenor/tenor_attribution.png" alt="{{t 'Powered By Tenor' }}" />
        </div>
    </div>
</div>
