<span class="stream-or-topic-reference">
    {{~#if stream~}}
        {{~> inline_decorated_stream_name stream=stream show_colored_icon=show_colored_icon}}
        &gt;
    {{~/if~}}
    {{#if is_empty_string_topic}}
    <em class="empty-topic-display">{{t "general chat"}}</em>
    {{else}}
    <span>{{~ topic_display_name ~}}</span>
    {{/if}}
</span>
