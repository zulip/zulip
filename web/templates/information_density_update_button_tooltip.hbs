<div id="information_density_tooltip_template">
    <div class="tooltip-inner-content">
        <span>
            {{#if is_default_button}}
                {{#if is_current_value_default}}
                    {{#tr}}Current value: default ({default_value_string}){{/tr}}
                {{else}}
                    {{#tr}}
                        Reset to default ({default_value_string})
                    {{/tr}}
                    <br />
                    {{#tr}}
                        Current value: {current_value_string}
                    {{/tr}}
                {{/if}}
            {{else}}
                {{new_value_string}}
            {{/if}}
        </span>
    </div>
</div>
