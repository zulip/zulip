<span class="reply">
    {{#if thumbnail_html}}<span class="reply-thumbnail-cell">{{{thumbnail_html}}}</span>{{/if}}
    <i class="zulip-icon zulip-icon-reply reply-icon" aria-hidden="true"></i>
    <a href="{{topic_url}}" class="referenced-message-topic-link {{#unless show_topic_url}}hidden{{/unless}}">{{topic_url_text}}</a>
    {{#if mention_html}}
    {{! A diffed mention (edit history): the highlight spans are rendered verbatim. }}
    <span class="reply-user-mention">{{{mention_html}}}</span>
    {{else}}
    <span class="user-mention reply-user-mention {{#if silent_mention}}silent{{/if}}" data-user-id="{{user_id}}" data-full-name="{{full_name}}">
        @{{~full_name~}}
    </span>
    {{/if}}
    <a class="referenced-message-link" href="{{link_to_message}}">{{{content_html}}}</a>
    {{#if include_reply_action_buttons}}
    {{#if silent_mention}}
    {{> components/icon_button custom_classes="compose-reply-mention-toggle reply-action-button" intent="neutral" icon="at-sign"}}
    {{else}}
    {{> components/icon_button custom_classes="compose-reply-mention-toggle reply-action-button" intent="neutral" icon="at-sign-crossed"}}
    {{/if}}
    {{> components/icon_button custom_classes="remove-reply-button reply-action-button" intent="neutral" icon="close-small"}}
    {{/if}}
</span>
