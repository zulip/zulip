<div class="bot-api-key-container" data-api-key="{{api_key}}" data-user-id="{{bot_id}}">
    <div class="input-group">
        <label for="api-key" class="modal-field-label">{{t "API key"}}</label>
        <div class="api-key-details-container">
            <input type="text" autocomplete="off" name="api-key" class="modal_text_input api-key inline-block" value="{{ api_key }}" readonly/>
            <div class="buttons-container">
                <span>
                    {{> ../components/icon_button
                      icon="refresh-cw"
                      intent="brand"
                      custom_classes="bot-modal-regenerate-bot-api-key tippy-zulip-delayed-tooltip"
                      data-tippy-content=(t "Generate new API key")
                      }}
                </span>
                <span>
                    {{> ../components/icon_button
                      icon="close"
                      intent="neutral"
                      hidden=true
                      custom_classes="bot-modal-cancel-regenerate-bot-api-key tippy-zulip-delayed-tooltip"
                      aria-label=(t "Cancel key rotation")
                      data-tippy-content=(t "Cancel key rotation")
                      }}
                </span>
                {{> ../components/action_button
                  icon="exclamation-circle"
                  intent="warning"
                  variant="subtle"
                  label=(t "Confirm key rotation")
                  hidden=true
                  custom_classes="bot-modal-confirm-regenerate-bot-api-key"
                  aria-describedby="bot-api-key-regenerate-warning"
                  }}
                <span>
                    {{> ../components/icon_button
                      icon="copy"
                      intent="success"
                      id="copy-api-key-button"
                      custom_classes="copy-api-key tippy-zulip-delayed-tooltip"
                      data-tippy-content=(t "Copy API key")
                      }}
                </span>
            </div>
        </div>
        <div id="bot-api-key-regenerate-warning" class="bot-api-key-regenerate-warning hide">{{t "This invalidates the current API key. Integrations using the old key will stop working." }}</div>
        <div class="bot-modal-api-key-error text-error"></div>
    </div>
</div>
