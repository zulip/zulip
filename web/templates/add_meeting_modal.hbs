<form id="add-meeting-form">
    <label class="meeting-label">{{t "Meeting title (optional)"}}</label>
    <div class="meeting-title-input-container">
        <input type="text" id="meeting-title-input" autocomplete="off" class="modal_text_input" placeholder="{{t 'e.g., Sprint Planning'}}" maxlength="100" />
    </div>
    <p class="meeting-description">{{t "A meeting card will be posted to this conversation. Participants can join directly from the card."}}</p>
</form>
