{{#if development_environment}}
<div class="alert" id="dev_env_msg"></div>
{{/if}}
<div class="input-group">
    <label for="deletes_in">{{t "After how much time should all data for this organization be permanently deleted (users, channels, messages, etc.)?" }}</label>
    <select id="deletes_in" class="modal_select bootstrap-focus-style">
        {{#each delete_in_options}}
            <option {{#if this.default }}selected{{/if}} name="delete_in" value="{{this.value}}">{{this.description}}</option>
        {{/each}}
    </select>
    <p class="time-input-formatted-description"></p>
    <div id="custom-realm-deletion-time" class="dependent-settings-block custom-time-input-container">
        <label for="deletes_in">{{custom_label_text}}</label>
        <input type="text" autocomplete="off" name="custom-deletion-time" id="custom-deletion-time-input" class="custom-time-input-value inline-block modal_text_input" value="" maxlength="4"/>
        <select class="custom-time-input-unit bootstrap-focus-style modal_select" id="custom-deletion-time-unit">
            {{#each time_choices}}
                <option name="custom_time_choice" class="custom_time_choice" value="{{this}}">{{this}}</option>
            {{/each}}
        </select>
        <p class="custom-time-input-formatted-description"></p>
    </div>
</div>
<p>{{t "Are you sure you want to deactivate this organization? All users will lose access to their Zulip accounts." }}</p>
