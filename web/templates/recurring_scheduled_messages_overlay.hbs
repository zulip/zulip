<div id="recurring_scheduled_messages_overlay" class="overlay" data-overlay="recurring-scheduled">
    <div class="flex overlay-content">
        <div class="overlay-messages-container overlay-container recurring-scheduled-messages-container">
            <div class="overlay-messages-header">
                <h1>{{t 'Recurring scheduled messages' }}</h1>
                <button type="button" class="button small rounded rsm-create-btn">
                    {{t 'Create recurring message' }}
                </button>
                <div class="exit">
                    <span class="exit-sign">&times;</span>
                </div>
            </div>
            <div class="recurring-scheduled-messages-list overlay-messages-list">
                <div class="no-overlay-messages">
                    {{t 'No recurring scheduled messages.'}}
                </div>
            </div>
        </div>
    </div>
</div>
