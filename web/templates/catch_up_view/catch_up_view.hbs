<div id="catch-up-main">
    {{#if loading}}
    <div id="catch-up-loading" class="catch-up-loading">
        <div class="loading_indicator_spinner"></div>
        <span>{{t "Loading catch-up data…" }}</span>
    </div>
    {{else if has_no_data}}
    <div class="catch-up-empty">
        <div class="catch-up-empty-icon">
            <i class="zulip-icon zulip-icon-check-circle" aria-hidden="true"></i>
        </div>
        <h2>{{t "You're all caught up!" }}</h2>
        <p>{{t "No new activity since you were last active." }}</p>
    </div>
    {{else}}
    <div class="catch-up-header">
        <div class="catch-up-header-text">
            <h1>{{t "What did I miss?" }}</h1>
            <p class="catch-up-subtitle">
                {{catch_up_period_display}}
            </p>
        </div>
        <div class="catch-up-stats">
            <span class="catch-up-stat">
                <i class="zulip-icon zulip-icon-message-square" aria-hidden="true"></i>
                {{total_messages}} {{t "messages" }}
            </span>
            <span class="catch-up-stat">
                <i class="zulip-icon zulip-icon-hash" aria-hidden="true"></i>
                {{total_topics}} {{t "topics" }}
            </span>
        </div>
    </div>
    {{#if time_saved}}
    {{> catch_up_time_saved time_saved}}
    {{/if}}
    <div class="catch-up-filters" role="group" aria-label="{{t 'Filters' }}">
        <div class="catch-up-filter-buttons">
            <button class="catch-up-filter-btn {{#if is_all_filter}}active{{/if}}" data-filter="all" tabindex="0">
                {{t "All" }}
            </button>
            <button class="catch-up-filter-btn {{#if is_mentions_filter}}active{{/if}}" data-filter="mentions" tabindex="0">
                <i class="zulip-icon zulip-icon-at-sign" aria-hidden="true"></i>
                {{t "Mentions" }}
            </button>
            <button class="catch-up-filter-btn {{#if is_important_filter}}active{{/if}}" data-filter="important" tabindex="0">
                <i class="zulip-icon zulip-icon-star" aria-hidden="true"></i>
                {{t "Important" }}
            </button>
            <button class="catch-up-filter-btn {{#if is_ai_summary_filter}}active{{/if}}" data-filter="ai-summary" tabindex="0">
                <i class="zulip-icon zulip-icon-bot" aria-hidden="true"></i>
                {{t "AI Summary" }}
            </button>
        </div>
        {{#if has_streams}}
        {{#unless is_ai_summary_filter}}
        <select id="catch-up-stream-filter" class="catch-up-stream-filter" aria-label="{{t 'Filter by channel' }}">
            <option value="all">{{t "All channels" }}</option>
            {{#each streams}}
            <option value="{{this.id}}">{{this.name}}</option>
            {{/each}}
        </select>
        {{/unless}}
        {{/if}}
    </div>
    {{#if is_ai_summary_filter}}
    <div class="catch-up-ai-summary-tab">
        <div class="catch-up-ai-summary-toolbar">
            <button type="button" id="catch-up-summary-prefs-toggle" class="catch-up-summary-prefs-toggle" aria-expanded="false" aria-controls="catch-up-preferences-collapsible">
                {{t "Instructions" }}
            </button>
            <button type="button" id="catch-up-regenerate-overview" class="catch-up-regenerate-overview-btn">
                {{t "Regenerate summary" }}
            </button>
        </div>
        <div id="catch-up-preferences-collapsible" class="catch-up-preferences-collapsible" style="display: none;" aria-label="{{t 'Summary preferences' }}">
            <label for="catch-up-summary-preferences" class="catch-up-preferences-label">{{t "Summary preferences" }}</label>
            <p class="catch-up-preferences-hint">{{t "Optional instructions added to the AI prompt (tone, focus, what to skip)." }}</p>
            <textarea id="catch-up-summary-preferences" class="catch-up-summary-preferences" rows="4" maxlength="4000" placeholder="{{t 'E.g. focus on decisions and blockers; skip social chatter.' }}">{{catch_up_summary_preferences_value}}</textarea>
        </div>
        <div id="catch-up-ai-summary-body" class="catch-up-ai-summary-body"></div>
    </div>
    {{else}}
    <div id="catch-up-no-filter-results" class="catch-up-no-filter-results" style="display: none;">
        {{t "No topics match your current filters." }}
    </div>
    <div class="catch-up-topics-container">
        {{#each topics}}
            {{> catch_up_topic_card this}}
        {{/each}}
    </div>
    {{/if}}
    {{/if}}
</div>
