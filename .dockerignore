# Git
.git
.gitignore
.gitattributes

# Development
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Documentation
docs/
*.md
!README.md

# Tests
**/tests/
**/test_*.py

# Build artifacts
*.egg-info/
dist/
build/

# Puppet - exclude most, but keep files needed at runtime
puppet/kandra/
puppet/zulip/manifests/
puppet/zulip/templates/
puppet/deps.yaml
# Keep: puppet/zulip/files/ (contains stop words for full-text search)

# Note: static/generated/ is NOT excluded - it contains pre-generated
# emoji data needed at import time before collectstatic runs

# Misc
*.log
.env*
.env.local
.env.*.local

# UV/pip cache
.uv/
uv.lock

# Node (if any frontend build)
node_modules/

# Docker files (don't need Dockerfile inside the context)
Dockerfile*
docker-compose*
