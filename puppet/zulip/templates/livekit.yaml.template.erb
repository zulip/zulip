# LiveKit server configuration — managed by Puppet.
# See https://docs.livekit.io/home/self-hosting/deployment/#config
port: <%= @livekit_port %>
rtc:
  tcp_port: <%= @livekit_rtc_tcp_port %>
  port_range_start: <%= @livekit_rtc_udp_port_start %>
  port_range_end: <%= @livekit_rtc_udp_port_end %>
  use_external_ip: true
keys:
  <%= @livekit_api_key %>: <%= @livekit_api_secret %>
logging:
  level: info
